# --- AWS ---
AWS_REGION=ap-south-1

# --- SQS ---
# The queue URL created by infrastructure/provision.py
SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/YOUR_ACCOUNT_ID/clauseguard-jobs
SQS_WAIT_TIME_SECONDS=20
SQS_VISIBILITY_TIMEOUT=300
SQS_MAX_MESSAGES=5

# --- S3 ---
S3_BUCKET_NAME=clauseguard-contracts-YOUR_ACCOUNT_ID

# NOTE: No DB_* variables needed. ClauseGuard uses DynamoDB, accessed via
# the ECS task IAM role. No database credentials are required.

# --- Textract ---
TEXTRACT_MAX_PAGES=20

# --- Worker behaviour ---
POLL_IDLE_SLEEP_SECONDS=2
LOG_LEVEL=INFO
